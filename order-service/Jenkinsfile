// Order Service 独立流水线
@Library('microservice-pipeline') _

pipeline {
    agent any

    environment {
        SERVICE_NAME = 'order-service'
        SERVICE_PORT = '8082'
        IMAGE_PREFIX = 'microservice-demo'
        DOCKER_NET = 'microservice-demo_microservice-net'
    }

    stages {
        stage('1. Checkout') {
            steps {
                echo '从 GitHub 拉取代码...'
                checkout scm
            }
        }

        stage('2. Build') {
            steps {
                echo "编译 ${env.SERVICE_NAME}..."
                script {
                    microservicePipeline.buildService(env.SERVICE_NAME)
                }
            }
        }

        stage('3. Test') {
            steps {
                echo "运行 ${env.SERVICE_NAME} 单元测试..."
                script {
                    microservicePipeline.testService(env.SERVICE_NAME)
                }
            }
        }

        stage('4. Docker Build') {
            steps {
                echo "构建 ${env.SERVICE_NAME} Docker 镜像..."
                script {
                    microservicePipeline.buildDockerImage(env.SERVICE_NAME, 'latest')
                }
            }
        }

        stage('5. Deploy') {
            steps {
                echo "部署 ${env.SERVICE_NAME}..."
                script {
                    microservicePipeline.waitForNacos()
                    microservicePipeline.deployService(env.SERVICE_NAME, env.DOCKER_NET)

                    echo '等待服务启动...'
                    sleep 30

                    microservicePipeline.checkServiceHealth(env.SERVICE_NAME)

                    echo "${env.SERVICE_NAME} 部署完成！"
                    sh "docker ps | grep ${env.SERVICE_NAME}"
                }
            }
        }
    }

    post {
        success {
            echo "${env.SERVICE_NAME} 构建成功！"
        }
        failure {
            echo "${env.SERVICE_NAME} 构建失败！"
        }
    }
}
